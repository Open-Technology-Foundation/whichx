# which - locate executables in PATH (script or sourceable function)
# Usage: which -h
# Usage: source which && which -h

which() {
  local -r VERSION=2.0

  local -i opt_all=0 opt_canonical=0 opt_silent=0
  local -i overall_rc=0 found=0
  local -a targets=() path_dirs=()
  local -- target path full_path resolved path_str

  _which_help() {
    cat <<HELP
which $VERSION - Locate executables in PATH

Usage: which [OPTIONS] [--] command ...

Options:
  -a, --all        Print all matches, not just first
  -c, --canonical  Resolve symlinks via realpath/readlink
  -q, --quiet      No output, exit code only
  -s, --silent     Same as -q
  -V, --version    Print version
  -h, --help       This help

Exit: 0=found, 1=not found, 2=no args, 22=bad option
HELP
  }

  _error() { ((opt_silent)) || >&2 printf 'which: error: %s\n' "$*"; }

  while (($#)); do
    case $1 in
      -a|--all)       opt_all=1 ;;
      -c|--canonical) opt_canonical=1 ;;
      -q|--quiet|-s|--silent)
                      opt_silent=1 ;;
      -V|--version)   printf 'which %s\n' "$VERSION"
                      return 0 ;;
      -h|--help)      _which_help
                      return 0 ;;
      --)             shift; targets+=("$@"); break ;;
      -[acqsVh]?*)    set -- "${1:0:2}" "-${1:2}" "${@:2}"; continue ;;
      -*)             _error "Illegal option ${1@Q}"
                      return 22 ;;
      *)              targets+=("$1") ;;
    esac
    shift
  done

  if ((!${#targets[@]})); then
    _error 'No arguments. See which --help'
    return 2
  fi

  for target in "${targets[@]}"; do
    found=0

    # Paths containing / bypass PATH search
    if [[ $target == */* ]]; then
      if [[ -f "$target" && -x "$target" ]]; then
        if ((opt_canonical)); then
          if resolved=$(realpath -- "$target" 2>/dev/null) || \
             resolved=$(readlink -f -- "$target" 2>/dev/null); then
            ((opt_silent)) || printf '%s\n' "$resolved"
            found=1
          else
            _error "Cannot resolve canonical path for ${target@Q}"
          fi
        else
          ((opt_silent)) || printf '%s\n' "$target"
          found=1
        fi
      fi
      ((found)) || overall_rc=1
      continue
    fi

    # Search PATH
    path_str=${PATH:-}
    if [[ $path_str == *: ]]; then
      path_str+='.'
    fi
    IFS=':' read -ra path_dirs <<< "$path_str"

    for path in "${path_dirs[@]}"; do
      [[ -n $path ]] || path='.'
      full_path="${path%/}/$target"

      if [[ -f "$full_path" && -x "$full_path" ]]; then
        if ((opt_canonical)); then
          if resolved=$(realpath -- "$full_path" 2>/dev/null) || \
             resolved=$(readlink -f -- "$full_path" 2>/dev/null); then
            ((opt_silent)) || printf '%s\n' "$resolved"
            found=1
          else
            _error "Cannot resolve canonical path for ${full_path@Q}"
          fi
        else
          ((opt_silent)) || printf '%s\n' "$full_path"
          found=1
        fi
        ((opt_all)) || break
      fi
    done

    ((found)) || overall_rc=1
  done

  return "$overall_rc"
}
declare -fx which

[[ ${BASH_SOURCE[0]} == "$0" ]] || return 0

# --- Script mode (direct execution only) ---
set -euo pipefail
shopt -s inherit_errexit shift_verbose

which "$@"
#fin
