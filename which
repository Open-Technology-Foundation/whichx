# which - locate executables in PATH; drop-in for debianutils which, plus -c/-s.
# Dual-mode: run directly, or `source` it to define the which() function.
# Options precede operands (the first operand ends option parsing, getopts-style).
# Exit: 0=found, 1=not found or no args, 2=invalid option. See 'which -h'.
#shellcheck disable=SC2317 # False positive on which "$@" in the source fence

# Require Bash 4.4+ (uses ${var@Q} and shopt -s inherit_errexit). Inline per-
# component check, not BCS0409's require_bash predicates: defining global helper
# functions would leak them into every shell that sources this file.
((BASH_VERSINFO[0] > 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] >= 4))) || {
  >&2 printf 'which: requires Bash >= 4.4 (have %s)\n' "${BASH_VERSION:-unknown}"
  return 2 2>/dev/null || exit 2
}

which() {
  local -r VERSION='2.0'
  local -i allmatches=0 canonical=0 silent=0 allret=0 found=0
  local -a targets=() path_dirs=()
  local -- target path full_path resolved

  while (($#)); do
    case $1 in
      -a|--all)       allmatches=1 ;;
      -c|--canonical) canonical=1 ;;
      -s|--silent)    silent=1 ;;
      -V|--version)   printf 'which %s\n' "$VERSION"; return 0 ;;
      -h|--help)
        cat <<HELP
which $VERSION - Locate executables in PATH

Usage: which [OPTIONS] [--] command ...

Options:
  -a, --all        Print all matches, not just first
  -c, --canonical  Resolve symlinks via realpath
  -s, --silent     No output, exit code only
  -V, --version    Print version
  -h, --help       This help

Exit: 0=found, 1=not found, 2=bad option
HELP
        return 0 ;;
      --)             shift; targets+=("$@"); break ;;
      # Split combined short options: -ac → -a -c
      -[acsVh]?*)     set -- "${1:0:2}" "-${1:2}" "${@:2}"; continue ;;
      # First operand ends option parsing (debianutils getopts parity): a bare
      # '-' or any non-option argument, and everything after it, are literal targets.
      -)              targets+=("$@"); break ;;
      -*)             >&2 printf 'Illegal option %s\n' "${1@Q}"; return 2 ;;
      *)              targets+=("$@"); break ;;
    esac
    shift
  done

  ((${#targets[@]})) || return 1

  # POSIX: trailing colon means current directory — guard for read -ra
  local -- _path=${PATH:-}
  [[ $_path != *: ]] || _path+=':'
  IFS=':' read -ra path_dirs <<< "$_path"

  for target in "${targets[@]}"; do
    found=0
    # Paths containing / bypass PATH search
    if [[ $target == */* ]]; then
      if [[ -f $target && -x $target ]]; then
        if ((canonical)); then
          # Pin PATH so realpath cannot be hijacked by the PATH being searched
          if resolved=$(PATH=/usr/bin:/bin realpath -- "$target" 2>/dev/null) && [[ -n $resolved ]]; then
            ((silent)) || printf '%s\n' "$resolved"
            found=1
          else
            ((silent)) || >&2 printf 'Cannot resolve canonical path for %s\n' "${target@Q}"
          fi
        else
          ((silent)) || printf '%s\n' "$target"
          found=1
        fi
      fi
      ((found)) || allret=1
      continue
    fi

    for path in "${path_dirs[@]}"; do
      # POSIX: empty PATH element means current directory
      [[ -n $path ]] || path='.'
      full_path="$path/$target"

      if [[ -f $full_path && -x $full_path ]]; then
        if ((canonical)); then
          # Pin PATH so realpath cannot be hijacked by the PATH being searched
          if resolved=$(PATH=/usr/bin:/bin realpath -- "$full_path" 2>/dev/null) && [[ -n $resolved ]]; then
            ((silent)) || printf '%s\n' "$resolved"
            found=1
          else
            ((silent)) || >&2 printf 'Cannot resolve canonical path for %s\n' "${full_path@Q}"
          fi
        else
          ((silent)) || printf '%s\n' "$full_path"
          found=1
        fi
        ((allmatches)) || break
      fi
    done

    ((found)) || allret=1
  done

  return "$allret"
}
# Deliberately NOT 'declare -fx which' (BCS0404 deviation): exporting the function
# shadows the system which in every child bash and leaks this implementation's
# semantics. Sourced callers still get which() in their own shell; children of
# those shells resolve the real which binary on PATH.

# --- source fence ---
return 0 2>/dev/null || {
  # --- direct execution ---
  set -euo pipefail
  shopt -s inherit_errexit
  which "$@"
}

#fin
