# which - locate executables in PATH (script or sourceable function)
# Usage: which -h

which() {
  local -i allmatches=0 canonical=0 silent=0 allret=0 found=0
  local -a targets=() path_dirs=()
  local -- target path full_path resolved

  _which_help() {
    cat <<'HELP'
which 2.0 - Locate executables in PATH

Usage: which [OPTIONS] [--] command ...

Options:
  -a, --all        Print all matches, not just first
  -c, --canonical  Resolve symlinks via realpath
  -s, --silent     No output, exit code only
  -V, --version    Print version
  -h, --help       This help

Exit: 0=found, 1=not found, 2=bad option
HELP
  }

  while (($#)); do
    case $1 in
      -a|--all)       allmatches=1 ;;
      -c|--canonical) canonical=1 ;;
      -s|--silent)    silent=1 ;;
      -V|--version)   printf 'which 2.0\n'
                      return 0 ;;
      -h|--help)      _which_help
                      return 0 ;;
      --)             shift; targets+=("$@"); break ;;
      # Split combined short options: -ac → -a -c
      -[acsVh]?*)     set -- "${1:0:2}" "-${1:2}" "${@:2}"; continue ;;
      -*)             >&2 printf 'Illegal option %s\n' "${1@Q}"
                      return 2 ;;
      *)              targets+=("$1") ;;
    esac
    shift
  done

  ((${#targets[@]})) || return 1

  # POSIX: trailing colon means current directory — guard for read -ra
  local _path="${PATH:-}"
  [[ $_path == *: ]] && _path+=':'
  IFS=':' read -ra path_dirs <<< "$_path"

  for target in "${targets[@]}"; do
    found=0

    # Paths containing / bypass PATH search
    if [[ $target == */* ]]; then
      if [[ -f "$target" && -x "$target" ]]; then
        if ((canonical)); then
          if resolved=$(realpath -- "$target" 2>/dev/null); then
            ((silent)) || printf '%s\n' "$resolved"
            found=1
          else
            ((silent)) || >&2 printf 'Cannot resolve canonical path for %s\n' "${target@Q}"
          fi
        else
          ((silent)) || printf '%s\n' "$target"
          found=1
        fi
      fi
      ((found)) || allret=1
      continue
    fi

    for path in "${path_dirs[@]}"; do
      # POSIX: empty PATH element means current directory
      [[ -n $path ]] || path='.'
      full_path="${path%/}"/"$target"

      if [[ -f "$full_path" && -x "$full_path" ]]; then
        if ((canonical)); then
          if resolved=$(realpath -- "$full_path" 2>/dev/null); then
            ((silent)) || printf '%s\n' "$resolved"
            found=1
          else
            ((silent)) || >&2 printf 'Cannot resolve canonical path for %s\n' "${full_path@Q}"
          fi
        else
          ((silent)) || printf '%s\n' "$full_path"
          found=1
        fi
        ((allmatches)) || break
      fi
    done

    ((found)) || allret=1
  done

  return "$allret"
}
# Export function to subshells (supports: source which && bash -c 'which ls')
declare -fx which

[[ ${BASH_SOURCE[0]} == "$0" ]] || return 0

# --- Script mode (direct execution only) ---
set -euo pipefail
shopt -s inherit_errexit shift_verbose

which "$@"
#fin
